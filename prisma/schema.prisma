// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider     = "postgresql"
    // NOTE: When using postgresql, mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url          = env("DATABASE_URL")
    relationMode = "prisma"
}

model Location {
    id          String   @id @default(cuid())
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    isDeleted   Boolean  @default(false)
    createdById String?
    createdBy   User?    @relation(fields: [createdById], references: [id])
    name        String
    address     String
    stops       Stop[]

    @@index([createdById])
}

enum DriverStopStatus {
    // Default status
    UNKNOWN
    // To let know driver is on stop.
    HERE
}

model Stop {
    id                String              @id @default(cuid())
    locationId        String
    location          Location            @relation(fields: [locationId], references: [id])
    time              String
    commute           Commute?            @relation(fields: [commuteId], references: [id])
    commuteId         String?
    commuteTemplate   CommuteTemplate?    @relation(fields: [commuteTemplateId], references: [id])
    commuteTemplateId String?
    passengers        PassengersOnStops[]
    driverStatus      DriverStopStatus    @default(UNKNOWN)

    @@index([locationId])
    @@index([commuteId])
    @@index([commuteTemplateId])
}

enum RequestStatus {
    CANCELED
    REQUESTED
    ACCEPTED
    REFUSED
}

enum StopStatus {
    UNKNOWN
    ON_TIME
    AWAITING
    DELAYED
}

enum TripType {
    ROUND
    OUTBOUND
    RETURN
}

model PassengersOnStops {
    user           User          @relation(fields: [userId], references: [id])
    userId         String
    stop           Stop          @relation(fields: [stopId], references: [id], onDelete: Cascade)
    stopId         String
    requestStatus  RequestStatus @default(REQUESTED)
    stopStatus     StopStatus    @default(UNKNOWN)
    requestComment String?       @db.Text
    tripType       TripType      @default(OUTBOUND)
    // Passenger is late, number of minutes of delay.
    delay          Int?

    @@id([userId, stopId])
    @@index([userId])
    @@index([stopId])
}

model CommuteTemplate {
    id           String   @id @default(cuid())
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    isDeleted    Boolean  @default(false)
    createdById  String?
    createdBy    User?    @relation(fields: [createdById], references: [id])
    stops        Stop[]
    seatsOutbound Int?
    seatsReturn  Int?
    comment      String?  @db.Text
    templateName String?  @db.Text
    commuteType  CommuteType @default(OUTBOUND)
    departureTime DateTime?  @default(now())
    returnTime DateTime?  @default(now())

    @@index([createdById])
}

enum CommuteStatus {
    UNKNOWN
    ON_TIME
    DELAYED
}

enum CommuteType {
  ROUND
  OUTBOUND
  RETURN
}

model Commute {
    id          String        @id @default(cuid())
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    isDeleted   Boolean?      @default(false)
    createdBy   User?         @relation(fields: [createdById], references: [id])
    createdById String
    date        DateTime
    seatsOutbound Int?
    seatsReturn  Int?
    commuteType CommuteType   @default(OUTBOUND)
    departureTime DateTime?
    returnTime DateTime?      @default(now())
    // "ON_TIME | DELAYED"
    status      CommuteStatus @default(UNKNOWN)
    // If the driver is late, number of minutes of delay
    delay       Int?
    stops       Stop[]
    comment     String?       @db.Text

    @@index([createdById])
}

// Necessary for Next auth
model Account {
    id                String   @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?  @db.Text
    access_token      String?  @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?  @db.Text
    session_state     String?
    user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    // Useful for Slack authentication
    ok                Boolean?
    state             String?

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

enum UserRole {
    USER
    ADMIN
}

model User {
    id                  String              @id @default(cuid())
    name                String?
    email               String?             @unique
    emailVerified       DateTime?
    image               String?
    phone               String?
    accounts            Account[]
    sessions            Session[]
    locations           Location[]
    commuteTemplates    CommuteTemplate[]
    commutes            Commute[]
    role                UserRole?           @default(USER)
    passengerOn         PassengersOnStops[]
    slackMemberId       String?
    isAutoAcceptEnabled Boolean             @default(false)

    @@unique([slackMemberId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
