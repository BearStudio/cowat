// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider     = "mysql"
    // NOTE: When using postgresql, mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url          = env("DATABASE_URL")
    relationMode = "prisma"
}

model Location {
    id          String   @id @default(cuid())
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    isDeleted   Boolean  @default(false)
    createdById String?
    createdBy   User?    @relation(fields: [createdById], references: [id])
    name        String
    address     String
    stops       Stop[]

    @@index([createdById])
}

model Stop {
    id                          String                        @id @default(cuid())
    createdAt                   DateTime                      @default(now())
    updatedAt                   DateTime                      @updatedAt
    isDeleted                   Boolean                       @default(false)
    createdById                 String?
    createdBy                   User?                         @relation(fields: [createdById], references: [id])
    locationId                  String?
    location                    Location?                     @relation(fields: [locationId], references: [id])
    time                        String?
    stopsOnCommuteTemplates     StopsOnCommuteTemplates[]
    stopsOnCommutes             StopsOnCommutes[]
    passengersOnStopsOnCommutes PassengersOnStopsOnCommutes[]

    @@index([createdById, locationId])
}

model CommuteTemplate {
    id                      String                    @id @default(cuid())
    createdAt               DateTime                  @default(now())
    updatedAt               DateTime                  @updatedAt
    isDeleted               Boolean                   @default(false)
    createdById             String?
    createdBy               User?                     @relation(fields: [createdById], references: [id])
    stopsOnCommuteTemplates StopsOnCommuteTemplates[]

    @@index([createdById])
}

model StopsOnCommuteTemplates {
    stop              Stop            @relation(fields: [stopId], references: [id])
    stopId            String
    commuteTemplate   CommuteTemplate @relation(fields: [commuteTemplateId], references: [id])
    commuteTemplateId String

    @@id([stopId, commuteTemplateId])
    @@index([stopId, commuteTemplateId])
}

enum CommuteStatus {
    UNKNOWN
    ON_TIME
    DELAYED
}

model Commute {
    id                          String                        @id @default(cuid())
    createdAt                   DateTime                      @default(now())
    updatedAt                   DateTime                      @updatedAt
    isDeleted                   Boolean?                      @default(false)
    createdBy                   User?                         @relation(fields: [createdById], references: [id])
    createdById                 String
    date                        DateTime
    seats                       Int
    // "ON_TIME | DELAYED"
    status                      CommuteStatus                 @default(UNKNOWN)
    // If the driver is late, number of minutes of delay
    delay                       Int?
    stopsOnCommutes             StopsOnCommutes[]
    passengersOnStopsOnCommutes PassengersOnStopsOnCommutes[]

    @@index([createdById])
}

model StopsOnCommutes {
    stop      Stop    @relation(fields: [stopId], references: [id])
    stopId    String
    commute   Commute @relation(fields: [commuteId], references: [id])
    commuteId String

    @@id([stopId, commuteId])
    @@index([stopId, commuteId])
}

enum RequestStatus {
    REQUESTED
    ACCEPTED
    REFUSED
}

enum StopStatus {
    UNKNOWN
    ON_TIME
    AWAITING
    DELAYED
}

model PassengersOnStopsOnCommutes {
    user          User          @relation(fields: [userId], references: [id])
    userId        String
    commute       Commute       @relation(fields: [commuteId], references: [id])
    commuteId     String
    stop          Stop          @relation(fields: [stopId], references: [id])
    stopId        String
    requestStatus RequestStatus @default(REQUESTED)
    stopStatus    StopStatus    @default(UNKNOWN)
    // Passenger is late, number of minutes of delay.
    delay         Int?

    @@id([userId, commuteId, stopId])
    @@index([userId, commuteId, stopId])
}

// Necessary for Next auth
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model User {
    id                          String                        @id @default(cuid())
    name                        String?
    email                       String?                       @unique
    emailVerified               DateTime?
    image                       String?
    phone                       String?
    accounts                    Account[]
    sessions                    Session[]
    stops                       Stop[]
    locations                   Location[]
    commuteTemplates            CommuteTemplate[]
    commutes                    Commute[]
    passengersOnStopsOnCommutes PassengersOnStopsOnCommutes[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
