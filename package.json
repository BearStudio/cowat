{
  "name": "cowat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "pnpm ssl:proxy & next dev",
    "postinstall": "prisma generate && yarn theme:generate-typing",
    "lint": "next lint",
    "start": "next start",
    "ssl:generate": "mkcert localhost",
    "ssl:proxy": "npx local-ssl-proxy --key localhost-key.pem --cert localhost.pem --source 3001 --target 3000",
    "theme:generate-typing": "chakra-cli tokens ./src/theme/theme.ts",
    "db:push": "prisma db push",
    "db:ui": "prisma studio"
  },
  "dependencies": {
    "@chakra-ui/react": "2.4.9",
    "@emotion/react": "11.10.5",
    "@emotion/styled": "11.10.5",
    "@formiz/core": "2.0.0-alpha.14",
    "@formiz/validations": "alpha",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "^4.9.0",
    "@tanstack/react-query": "^4.23.0",
    "@trpc/client": "^10.9.0",
    "@trpc/next": "^10.9.0",
    "@trpc/react-query": "^10.9.0",
    "@trpc/server": "^10.9.0",
    "dayjs": "1.11.7",
    "framer-motion": "8.5.3",
    "lucide-react": "0.109.0",
    "next": "13.1.5",
    "next-auth": "^4.18.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "4.7.1",
    "react-use-measure": "2.1.1",
    "remeda": "1.6.1",
    "slack-notify": "2.0.6",
    "superjson": "1.12.2",
    "zod": "^3.20.2"
  },
  "devDependencies": {
    "@babel/core": "7.20.12",
    "@chakra-ui/cli": "2.3.0",
    "@chakra-ui/styled-system": "2.5.1",
    "@types/node": "^18.11.18",
    "@types/prettier": "^2.7.2",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "eslint": "^8.32.0",
    "eslint-config-next": "13.1.5",
    "local-ssl-proxy": "1.3.0",
    "prettier": "^2.8.3",
    "prisma": "^4.9.0",
    "typescript": "^4.9.4"
  },
  "ct3aMetadata": {
    "initVersion": "7.3.1"
  }
}
